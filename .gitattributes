# Force LF on all text files checked out on any OS
* text=auto eol=lf

# Gradle wrapper scripts must always be LF (even on Windows)
gradlew     text eol=lf
gradlew.bat text eol=crlf

# Treat wrapper jar as binary — never mangle line endings
gradle/wrapper/gradle-wrapper.jar binary

# Kotlin / Java / XML source
*.kt   text eol=lf
*.java text eol=lf
*.xml  text eol=lf
*.kts  text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.sh   text eol=lf

# PNG / binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.keystore binary
*.jks  binary
