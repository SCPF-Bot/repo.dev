<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_overlay"
    android:elevation="8dp">

    <!-- Drag handle / header -->
    <LinearLayout
        android:id="@+id/overlay_handle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/colorPrimaryContainer">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_title"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnPrimaryContainer" />

        <ImageButton
            android:id="@+id/btn_close_overlay"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_close_desc"
            android:tint="?attr/colorOnPrimaryContainer" />

    </LinearLayout>

    <!-- Suggestion list (tap header to collapse/expand) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_overlay_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingVertical="4dp"
        android:nestedScrollingEnabled="false" />

</LinearLayout>
