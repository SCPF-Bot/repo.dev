  "detection_notes": {
    "ban_slot_fill_detection": "A ban slot transitions from dark (empty) to bright (hero portrait visible). Compare mean luminance of the slot crop against a normalized baseline. See FrameProcessor.isSlotFilled(). Only scan the slots active for the current rank — use BanSlotTemplates.forRank().",
    "ban_template_selection": "Call BanDraftType.fromRank(session.rank) to resolve the BanDraftType, then BanSlotTemplates.forDraftType(type) to get the active slot list. Scanning slots 3–4 at Epic rank checks screen regions with no ban slots, causing false positives.",
    "pick_slot_fill_detection": "Same luminance approach as bans. Hero portrait appears in the hero_portrait_x_abs sub-region of each row.",
    "phase_detection": "Sample the action_button region: red-dominant → BAN phase, blue/teal-dominant → PICK phase. See PhaseDetector.",
    "timer_ocr": "Crop countdown_timer region and run OCR to read remaining seconds. Large white number on dark background — high contrast.",
    "ban_icon_recognition": "Each ban slot shows a circular hero portrait with a red X overlay when filled. Use PortraitMatcher.match() on the cropped slot.",
    "orientation_warning": "MLBB draft is always landscape. Do NOT apply portrait-mode coordinates — they will target the wrong screen areas."
  }
