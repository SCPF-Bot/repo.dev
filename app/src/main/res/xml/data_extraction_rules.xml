<?xml version="1.0" encoding="utf-8"?>
<!--
   Sample data extraction rules file; see:
   https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the Room database from cloud backup to avoid stale data -->
        <exclude domain="database" path="mlbb_assistant.db" />
        <exclude domain="database" path="mlbb_assistant.db-shm" />
        <exclude domain="database" path="mlbb_assistant.db-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
