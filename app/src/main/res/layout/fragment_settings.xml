<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_settings"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Overlay toggle ───────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp" app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_overlay_label"
                        android:textAppearance="?attr/textAppearanceTitleMedium"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_overlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Overlay controls (visible only when enabled) ─────────── -->
            <LinearLayout
                android:id="@+id/group_overlay_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_opacity_label"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_opacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.2"
                    android:valueTo="1.0"
                    android:stepSize="0.05"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <!-- ── Suggestion count ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_suggestion_count_label"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="10"
                android:stepSize="1"
                android:layout_marginBottom="16dp"/>

            <!-- ── Scoring weights ──────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_weights_label"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_weight_meta"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_weight_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0" android:valueTo="1.0" android:stepSize="0.05"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_weight_counter"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_weight_counter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0" android:valueTo="1.0" android:stepSize="0.05"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_weight_synergy"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_weight_synergy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0" android:valueTo="1.0" android:stepSize="0.05"
                android:layout_marginBottom="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_weights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_save_weights"
                android:layout_marginBottom="24dp"/>

            <!-- ── Remote API URL ────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_url_label"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_url_hint_body"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_api_url_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_api_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:imeOptions="actionDone"
                    android:singleLine="true"/>
            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_api_url"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_api_url_save"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_api_url"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_api_url_clear"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
