<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon for the DevLogAlias activity-alias.
    A simple bug/bug-report style icon that is visually distinct from the main
    app launcher (which uses ic_launcher). Rendered as an adaptive icon foreground
    when used on API 26+ devices; on older devices the drawable is used directly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Dark background circle -->
    <path
        android:fillColor="#1A1A2E"
        android:pathData="M0,0 L24,0 L24,24 L0,24 Z" />

    <!-- Bug body (ellipse) -->
    <path
        android:fillColor="#FFD700"
        android:pathData="M12,8 C9.24,8 7,10.24 7,13 C7,15.76 9.24,18 12,18 C14.76,18 17,15.76 17,13 C17,10.24 14.76,8 12,8 Z" />

    <!-- Bug head -->
    <path
        android:fillColor="#FFD700"
        android:pathData="M12,6 C10.9,6 10,6.9 10,8 L14,8 C14,6.9 13.1,6 12,6 Z" />

    <!-- Left antenna -->
    <path
        android:strokeColor="#FFD700"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M10,6 L8,4" />

    <!-- Right antenna -->
    <path
        android:strokeColor="#FFD700"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M14,6 L16,4" />

    <!-- Left legs -->
    <path
        android:strokeColor="#FFD700"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:pathData="M7,11 L4,10 M7,13 L4,13 M7,15 L4,16" />

    <!-- Right legs -->
    <path
        android:strokeColor="#FFD700"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:pathData="M17,11 L20,10 M17,13 L20,13 M17,15 L20,16" />
</vector>
